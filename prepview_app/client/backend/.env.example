# Copy to .env in this same folder (backend/.env) and fill in values.
# Restart the backend after changes.
#
# Note: `npm run server` runs from the client/ folder, but server.js loads
# env from this file explicitly — not from client/.env.

# Server
PORT=5000

# Auth (use a long random string in production)
JWT_SECRET=your-secret-key-change-in-production

# Base URL of the Next app (password reset emails link here; no trailing slash)
APP_PUBLIC_URL=http://localhost:3000

# PostgreSQL (Prisma; run migrate/generate from the client app root if your workflow uses client/.env)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME

# --- Email (password reset) — required for forgot-password ---
# Gmail: use an App Password (Google Account → Security → 2-Step Verification → App passwords), not your normal password.
SMTP_USER=you@example.com
SMTP_PASS=

# Optional overrides (defaults match Gmail on port 587)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false

# Optional “From” header (defaults to "PrepView" <SMTP_USER>)
# MAIL_FROM="PrepView" <you@example.com>

# AI (interview features)
# GROQ_API_KEY=

# Optional temp uploads override
# PREPVIEW_TEMP_UPLOADS=
